aws_region                = "eu-north-1"
environment               = "dev"
instance_type             = "t3.micro"
# Locally: set immutable tags for both. In GitHub Actions, workflows set TF_VAR_* from the latest successful ci.yml on main.
docker_image              = "YOUR_DOCKERHUB_USER/devops-api:tfvars-placeholder-use-tf-var"
worker_image              = "YOUR_DOCKERHUB_USER/devops-worker:tfvars-placeholder-use-tf-var"
ami_id                    = "ami-0c1ac8a41498c1a9c"
ssh_allowed_cidrs         = ["203.0.113.10/32"] # Replace with your public IPv4 /32
enable_ecs                = true
enable_ec2                = false
enable_rds                = true
rds_instance_class        = "db.t4g.micro"
rds_allocated_storage     = 20
ecs_worker_desired_count  = 1
ecs_assign_public_ip      = false
vpc_cidr                  = "10.0.0.0/16"
public_subnet_cidrs       = ["10.0.1.0/24", "10.0.2.0/24"]
private_subnet_cidrs      = ["10.0.101.0/24", "10.0.102.0/24"]
